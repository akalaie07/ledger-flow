# Kopie als .env.local ablegen und Werte aus dem Supabase-/Stripe-Dashboard einsetzen.

# Supabase: Project Settings → API (eigenes, neues Projekt — NICHT Kalaie Ledger prod)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Service-Role-Key NUR serverseitig verwenden (Webhook-Handler, Raten-Job).
# Niemals an den Client geben, niemals in den Chat/Code committen.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Basis-URL der App (für Checkout-Redirects success_url/cancel_url)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Stripe (Phase 2+) ───────────────────────────────────────────────────────
# Dashboard → Developers → API keys (Test-Mode-Keys für die Beta verwenden)
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
# Dashboard → Developers → Webhooks → Signing secret (nach Einrichtung des Endpoints)
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET
# Dashboard → Settings → Connect → Platform settings (für "Connect with Stripe")
STRIPE_CONNECT_CLIENT_ID=YOUR_STRIPE_CONNECT_CLIENT_ID

# Beliebiges Geheimnis; schützt den täglichen Raten-Abbuchungs-Job
CRON_SECRET=YOUR_CRON_SECRET
